{
  "$schema": "https://ocx.kdco.dev/schemas/v2/registry.json",
  "name": "Thompson OpenCode Workspace",
  "namespace": "thompsonsed",
  "version": "1.0.0",
  "author": "Sam Thompson",
  "opencode": "1.0.0",
  "ocx": "1.0.16",
  "components": [
    {
      "name": "ws",
      "type": "profile",
      "description": "Workspace profile with Atlassian integration, GitHub Copilot models, and extended skills",
      "files": [
        { "path": "profiles/ws/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/ws/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["workspace"]
    },
    {
      "name": "workspace",
      "type": "bundle",
      "description": "Complete workspace bundle with agents, plugins, skills, and commands",
      "files": [],
      "dependencies": [
        "coder",
        "researcher", 
        "reviewer",
        "scribe",
        "background-agents",
        "workspace-plugin",
        "worktree",
        "notify",
        "code-philosophy",
        "code-review",
        "frontend-philosophy",
        "plan-review",
        "plan-protocol",
        "atlassian",
        "github-cli",
        "python-uv",
        "review-command"
      ]
    },
    {
      "name": "coder",
      "type": "agent",
      "description": "Technical implementation specialist",
      "files": ["agent/coder.md"]
    },
    {
      "name": "researcher",
      "type": "agent", 
      "description": "Knowledge architect for external research",
      "files": ["agent/researcher.md"]
    },
    {
      "name": "reviewer",
      "type": "agent",
      "description": "Expert code reviewer",
      "files": ["agent/reviewer.md"]
    },
    {
      "name": "scribe",
      "type": "agent",
      "description": "Human-facing content specialist",
      "files": ["agent/scribe.md"]
    },
    {
      "name": "background-agents",
      "type": "plugin",
      "description": "Async delegation system with persistent storage",
      "files": ["plugin/background-agents.ts"],
      "dependencies": ["kdco-primitives"]
    },
    {
      "name": "workspace-plugin",
      "type": "plugin",
      "description": "Plan management and rule injection",
      "files": ["plugin/workspace-plugin.ts"],
      "dependencies": ["kdco-primitives"]
    },
    {
      "name": "worktree",
      "type": "plugin",
      "description": "Git worktree isolation",
      "files": [
        "plugin/worktree.ts",
        "plugin/worktree/state.ts",
        "plugin/worktree/terminal.ts"
      ],
      "dependencies": ["kdco-primitives"]
    },
    {
      "name": "notify",
      "type": "plugin",
      "description": "OS-level notifications on task completion",
      "files": ["plugin/notify.ts"],
      "dependencies": ["kdco-primitives"]
    },
    {
      "name": "kdco-primitives",
      "type": "plugin",
      "description": "Shared utilities for plugins",
      "files": [
        "plugin/kdco-primitives/index.ts",
        "plugin/kdco-primitives/get-project-id.ts",
        "plugin/kdco-primitives/log-warn.ts",
        "plugin/kdco-primitives/mutex.ts",
        "plugin/kdco-primitives/shell.ts",
        "plugin/kdco-primitives/temp.ts",
        "plugin/kdco-primitives/terminal-detect.ts",
        "plugin/kdco-primitives/types.ts",
        "plugin/kdco-primitives/with-timeout.ts"
      ]
    },
    {
      "name": "code-philosophy",
      "type": "skill",
      "description": "The 5 Laws of Elegant Defense",
      "files": [
        { "path": "skill/code-philosophy/SKILL.md", "target": ".opencode/skills/code-philosophy/SKILL.md" }
      ]
    },
    {
      "name": "code-review",
      "type": "skill",
      "description": "Review methodology with severity classification",
      "files": [
        { "path": "skill/code-review/SKILL.md", "target": ".opencode/skills/code-review/SKILL.md" }
      ]
    },
    {
      "name": "frontend-philosophy",
      "type": "skill",
      "description": "The 5 Pillars of Intentional UI",
      "files": [
        { "path": "skill/frontend-philosophy/SKILL.md", "target": ".opencode/skills/frontend-philosophy/SKILL.md" }
      ]
    },
    {
      "name": "plan-review",
      "type": "skill",
      "description": "Implementation plan review criteria",
      "files": [
        { "path": "skill/plan-review/SKILL.md", "target": ".opencode/skills/plan-review/SKILL.md" }
      ]
    },
    {
      "name": "plan-protocol",
      "type": "skill",
      "description": "Implementation planning guidelines with citations",
      "files": [
        { "path": "skill/plan-protocol/SKILL.md", "target": ".opencode/skills/plan-protocol/SKILL.md" }
      ]
    },
    {
      "name": "atlassian",
      "type": "skill",
      "description": "Atlassian MCP tools for Jira and Confluence",
      "files": [
        { "path": "skill/atlassian/SKILL.md", "target": ".opencode/skills/atlassian/SKILL.md" }
      ]
    },
    {
      "name": "github-cli",
      "type": "skill",
      "description": "GitHub CLI (gh) operations",
      "files": [
        { "path": "skill/github-cli/SKILL.md", "target": ".opencode/skills/github-cli/SKILL.md" }
      ]
    },
    {
      "name": "python-uv",
      "type": "skill",
      "description": "Python tooling with uv",
      "files": [
        { "path": "skill/python-uv/SKILL.md", "target": ".opencode/skills/python-uv/SKILL.md" }
      ]
    },
    {
      "name": "review-command",
      "type": "command",
      "description": "Code review slash command",
      "files": ["command/review.md"]
    }
  ]
}
